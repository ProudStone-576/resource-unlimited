# ------------------------------------------------------------
# Resources Unlimited — root env example
# Copy to .env in each app folder (apps/api/.env, apps/web/.env.local)
# ------------------------------------------------------------

# ---- Shared ----
NODE_ENV=development

# ---- Database (packages/db, apps/api) ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/resources_unlimited?schema=public"

# ---- API (apps/api) ----
API_PORT=4000
API_HOST=0.0.0.0
API_CORS_ORIGINS=http://localhost:3000

# JWT (used in later phase; reserved here so secrets are not added mid-flight)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Mail (quote + contact notifications)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=noreply@example.com
MAIL_PASS=
MAIL_FROM="Resources Unlimited <noreply@resourcesunlimited.ca>"
SALES_INBOX=sales@resourcesunlimited.ca

# Storage (Phase 1 not required; placeholders reserved)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
S3_REGION=ca-central-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ---- Web (apps/web) ----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Resources Unlimited"
