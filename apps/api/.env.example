NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0
API_CORS_ORIGINS=http://localhost:3000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/resources_unlimited?schema=public"

JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Resources Unlimited <noreply@resourcesunlimited.ca>"
SALES_INBOX=sales@resourcesunlimited.ca

# ---- Phase 2 ----
WEB_PUBLIC_URL=http://localhost:3000

# PDF storage — empty defaults to <cwd>/storage/quotes
QUOTE_PDF_DIR=
QUOTE_PDF_PUBLIC_BASE=/static/quotes

# Admin gate (Phase 3 replaces with JWT + RBAC). 16+ chars.
ADMIN_API_TOKEN=

# Recaptcha v3 (empty = bypass in dev)
RECAPTCHA_SECRET=
RECAPTCHA_MIN_SCORE=0.5

# Throttling (windows in seconds)
THROTTLE_TTL=60
THROTTLE_LIMIT=20
QUOTE_THROTTLE_TTL=3600
QUOTE_THROTTLE_LIMIT=5

# ---- Phase 3 — Auth ----
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_NAME_ACCESS=ru_access
AUTH_COOKIE_NAME_REFRESH=ru_refresh
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_PASSWORD_MIN_LENGTH=10
AUTH_EMAIL_VERIFY_TTL_MIN=1440
AUTH_PASSWORD_RESET_TTL_MIN=60

# ---- Phase 4 — Portal / Invoices ----
INVOICE_PDF_DIR=
INVOICE_PDF_PUBLIC_BASE=/static/invoices

# ---- Phase 5 — Uploads ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
S3_REGION=ca-central-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ---- Phase 6 — Integrations ----
HUBSPOT_API_TOKEN=
WEBHOOK_SIGNING_SECRET=
ANALYTICS_CACHE_SEC=120
